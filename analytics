// CSVLoader.h
#pragma once
#include "Employee.h"
#include <vector>
#include <fstream>
#include <sstream>

std::vector<Employee> loadEmployees(const std::string& filename) {
    std::vector<Employee> employees;
    std::ifstream file(filename);
    std::string line;

    getline(file, line); // skip header

    while (getline(file, line)) {
        std::stringstream ss(line);
        std::string token;

        Employee e;

        getline(ss, token, ','); e.id = std::stoi(token);
        getline(ss, token, ','); e.role = token;
        getline(ss, token, ','); e.tenure_months = std::stoi(token);

        std::vector<std::string> keys = {
            "delivery_score","quality_score","engagement",
            "manager_relationship","growth_opportunity","compa_ratio"
        };

        for (auto& key : keys) {
            getline(ss, token, ',');
            e.metrics[key] = std::stod(token);
        }

        employees.push_back(e);
    }

    return employees;
}

